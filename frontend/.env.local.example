# Next.js frontend — local development
# Copy to .env.local and fill in your values.

# The Craft CMS hostname (no protocol, no path) — used by Next.js to whitelist
# image domains. Set to your Deploio app hostname in production.
# Example: myapp.deploio.app
CRAFT_HOST=

# Full URL to the Craft GraphQL endpoint
CRAFT_GQL_URL=https://${CRAFT_HOST}/actions/graphql/api

# Bearer token for the Frontend GQL schema.
# After first deploy, run: php craft migrate/all
# The token is printed to the deploy log. Copy it here.
CRAFT_GQL_TOKEN=
