# Craft CMS — local development environment
# Copy to .env and fill in your local values.
# On Deploio, all NINE_* vars are injected automatically by service connections.

# A unique string used to store session/cache data. Generate with:
#   php craft setup/security-key
CRAFT_APP_ID=
CRAFT_SECURITY_KEY=

CRAFT_ENVIRONMENT=dev
CRAFT_DEV_MODE=true
CRAFT_ALLOW_ADMIN_CHANGES=true
CRAFT_DISALLOW_ROBOTS=true

# Local PostgreSQL (used when NINE_PG_* / NINE_PGDB_* vars are absent)
CRAFT_DB_DRIVER=pgsql
CRAFT_DB_SERVER=127.0.0.1
CRAFT_DB_PORT=5432
CRAFT_DB_DATABASE=craft
CRAFT_DB_USER=craft
CRAFT_DB_PASSWORD=craft
